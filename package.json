{
  "name": "pdfding",
  "version": "1.4.1",
  "license": "AGPL-3.0-only",
  "private": true,
  "dependencies": {
    "alpinejs": "3.15.12",
    "boxicons": "^2.1.4",
    "htmx.org": "2.0.10",
    "tailwindcss": "4.3.0",
    "terser": "5.48.0"
  },
  "scripts": {
    "build:alpine": "cp node_modules/alpinejs/dist/cdn.min.js pdfding/static/js/alpine.min.js",
    "build:htmx": "cp node_modules/htmx.org/dist/htmx.min.js pdfding/static/js/htmx.min.js",
    "build:boxicons": "cp node_modules/boxicons/css/boxicons.min.css pdfding/static/css/boxicons.css && cp -r node_modules/boxicons/fonts/. pdfding/static/fonts/",
    "build": "npm run build:alpine && npm run build:htmx && npm run build:boxicons"
  }
}
